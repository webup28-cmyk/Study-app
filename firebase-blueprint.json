{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and role.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] }
      },
      "required": ["email", "name", "role"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Stores subject metadata.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name", "icon", "color"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Stores studied and favorite questions for a user.",
      "type": "object",
      "properties": {
        "studied": { "type": "array", "items": { "type": "string" } },
        "favorites": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Answer": {
      "title": "Answer",
      "description": "Stores answer text and images for a question.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Question": {
      "title": "Question",
      "description": "Stores question text and metadata.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "subjectId": { "type": "string" },
        "series": { "type": "string" },
        "part": { "type": "string", "enum": ["A", "B"] },
        "number": { "type": "integer" }
      },
      "required": ["text", "subjectId", "series", "part", "number"]
    },
    "Note": {
      "title": "Module Note",
      "description": "Stores a note for a specific module, can be a PDF or a link.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "moduleId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "link", "video"] },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectId", "moduleId", "name", "type", "url"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "User",
      "description": "User profiles indexed by email."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subject definitions."
    },
    "/user_progress/{email}": {
      "schema": "UserProgress",
      "description": "Progress tracking for each user."
    },
    "/answers/{answerId}": {
      "schema": "Answer",
      "description": "Answers for questions, ID is a composite of subject, module, series, and question ID."
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Questions for subjects."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Notes for modules."
    }
  }
}
